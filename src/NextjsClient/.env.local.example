# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Custom SSO server URL
AUTH_ISSUER=https://localhost:5001

# OIDC client ID (registered in the SSO server)
AUTH_CLIENT_ID=nextjs-client

# Client secret (leave empty for public client with PKCE)
# AUTH_CLIENT_SECRET=

# Protected API URL
NEXT_PUBLIC_API_URL=https://localhost:5002

# Next.js URL (used for auth callbacks)
NEXTAUTH_URL=http://localhost:3000
