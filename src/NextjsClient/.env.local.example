# Auth.js session secret.
# Generate your own value with: openssl rand -base64 32
AUTH_SECRET=replace-this-with-a-generated-32-byte-secret

# Public base URL of the Next.js app.
# Used by Auth.js and federated logout redirect handling.
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Central Auth Server (OpenID Connect issuer)
AUTH_ISSUER=https://localhost:5001

# Public PKCE client registered in AuthServer SeedData
AUTH_CLIENT_ID=nextjs-client

# Downstream protected API base URL
NEXT_PUBLIC_API_URL=https://localhost:5002
