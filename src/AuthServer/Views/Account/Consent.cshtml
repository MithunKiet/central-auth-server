@model AuthServer.Models.ConsentViewModel
@{
    ViewData["Title"] = "Authorization Request";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Authorization Request</h1>
            <p><strong>@Model.ApplicationName</strong> is requesting access to your account.</p>
        </div>

        <div class="consent-scopes">
            <h5>Requested permissions:</h5>
            <ul class="list-unstyled">
                @foreach (var scope in Model.Scopes)
                {
                    <li class="consent-scope-item">
                        <span class="scope-badge">@scope</span>
                    </li>
                }
            </ul>
        </div>

        <form method="post" action="~/connect/authorize">
            @Html.AntiForgeryToken()
            <div class="consent-actions">
                <button type="submit" name="submit.Accept" value="true" class="btn btn-primary">Allow Access</button>
                <button type="submit" name="submit.Deny" value="true" class="btn btn-secondary">Deny</button>
            </div>
        </form>
    </div>
</div>
